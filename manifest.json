{
  "manifest_version": 3,
  "name": "Amazon 続きを読む割引率チェッカー",
  "version": "1.0.0",
  "description": "「読み始めたシリーズの続き」ページで、紙の本との差、ポイント、クーポンを考慮した実質割引率を計算・表示し、お得度に応じて書籍を色分けします。",

  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.co.jp/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
